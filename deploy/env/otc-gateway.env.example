NHB_ENV=prod
OTC_PORT=8086
OTC_DB_URL=postgres://user:pass@127.0.0.1:5432/otc?sslmode=disable
OTC_S3_BUCKET=replace-me
OTC_CHAIN_ID=1
OTC_SWAP_RPC_BASE=http://127.0.0.1:8545
OTC_SWAP_API_KEY=replace-me
OTC_SWAP_API_SECRET=replace-me
OTC_IDENTITY_BASE_URL=https://identity.nhbcoin.com
OTC_IDENTITY_API_KEY=replace-me
OTC_HSM_BASE_URL=https://hsm.internal
OTC_HSM_CA_CERT=/etc/nhbchain/tls/hsm-ca.pem
OTC_HSM_CLIENT_CERT=/etc/nhbchain/tls/hsm-client.pem
OTC_HSM_CLIENT_KEY=/etc/nhbchain/tls/hsm-client-key.pem
OTC_AUTH_JWT_ISSUER=https://nhbcoin.com
OTC_AUTH_JWT_AUDIENCE=nhbportal
OTC_AUTH_JWT_HS_SECRET_ENV=OTC_JWT_SECRET
OTC_WEBAUTHN_ENDPOINT=https://nhbcoin.com/api/webauthn/verify
OTC_WEBAUTHN_RPID=nhbcoin.com
OTC_WEBAUTHN_ORIGIN=https://nhbcoin.com
